<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            fx:controller="controller.GameController"
            prefWidth="1280" prefHeight="720">

    <!-- ==== GAME CANVAS ==== -->
    <Canvas fx:id="canvas"
            width="1280" height="720"
            AnchorPane.leftAnchor="0.0"
            AnchorPane.topAnchor="0.0" />

    <!-- ==== HUD (NYALA DI ATAS GAME) ==== -->
    <Label fx:id="lblHP"
           text="HP: 100"
           layoutX="20" layoutY="20"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <!-- Pause Overlay -->
    <AnchorPane fx:id="pauseOverlay"
                visible="false"
                managed="false"
                style="-fx-background-color: rgba(0,0,0,0.6);"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0"
                AnchorPane.topAnchor="0.0"
                AnchorPane.bottomAnchor="0.0">

        <VBox spacing="16"
              alignment="CENTER"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0">

            <Label text="PAUSED"
                   style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;" />

            <Label fx:id="lblPauseInfo"
                   text="Permainan dijeda"
                   style="-fx-text-fill: #dcedc8; -fx-font-size: 18px;" />

            <Button text="Lanjutkan"
                    onAction="#resumeGame"
                    prefWidth="220"
                    style="-fx-background-color: #66bb6a; -fx-text-fill: #0d2815; -fx-font-size: 18px; -fx-font-weight: bold;" />

            <Button text="Options"
                    onAction="#openOptions"
                    prefWidth="220"
                    style="-fx-background-color: #558b2f; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

            <Button text="Exit to Main Menu"
                    onAction="#exitToMenu"
                    prefWidth="220"
                    style="-fx-background-color: #b71c1c; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
        </VBox>

    </AnchorPane>

</AnchorPane>
