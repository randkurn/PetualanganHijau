<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MenuController"
            prefWidth="960" prefHeight="600"
            style="-fx-background-color: radial-gradient(radius 80%, #1b5e20, #0d2815);">

    <Label text="Petualangan Hijau"
           layoutX="120" layoutY="130"
           style="-fx-font-size: 64px; -fx-font-weight: bold; -fx-text-fill: #dcedc8;" />

    <Label text="Selamatkan bumi mulai dari satu langkah kecil."
           layoutX="130" layoutY="210"
           style="-fx-text-fill: #e8f5e9; -fx-font-size: 20px;" />

    <VBox spacing="20"
          AnchorPane.rightAnchor="160.0"
          AnchorPane.topAnchor="200.0">
        <Button fx:id="btnNewGame"
                text="New Game"
                onAction="#startNewGame"
                prefWidth="280"
                prefHeight="60"
                style="-fx-font-size: 22px; -fx-background-color: #66bb6a; -fx-text-fill: #0d2815; -fx-font-weight: bold;" />
        <Button fx:id="btnLoadGame"
                text="Load Game"
                onAction="#loadGame"
                prefWidth="280"
                prefHeight="60"
                style="-fx-font-size: 22px; -fx-background-color: #558b2f; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Button text="Options"
                onAction="#openOptions"
                prefWidth="280"
                prefHeight="60"
                style="-fx-font-size: 22px; -fx-background-color: #33691e; -fx-text-fill: white; -fx-font-weight: bold;" />
        <Button text="Quit Game"
            onAction="#exitGame"
                prefWidth="280"
                prefHeight="60"
                style="-fx-font-size: 22px; -fx-background-color: #b71c1c; -fx-text-fill: white; -fx-font-weight: bold;" />
    </VBox>
</AnchorPane>
