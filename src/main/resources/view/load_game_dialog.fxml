<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.LoadGameDialogController"
            prefWidth="360" prefHeight="240"
            style="-fx-background-color: #0d2815;">

    <VBox spacing="14"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.topAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <Label text="Pilih Slot untuk Dilanjutkan"
               style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

        <ChoiceBox fx:id="choiceSlot"
                   prefWidth="220" />

        <Label fx:id="lblInfo"
               text=""
               wrapText="true"
               style="-fx-text-fill: #dcedc8;" />

        <Button fx:id="btnLoad"
                text="Muat Game"
                onAction="#loadSlot"
                prefWidth="160"
                style="-fx-background-color: #66bb6a; -fx-text-fill: #0d2815; -fx-font-weight: bold;" />

        <Button text="Batal"
                onAction="#cancel"
                prefWidth="160"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white;" />

    </VBox>

</AnchorPane>

