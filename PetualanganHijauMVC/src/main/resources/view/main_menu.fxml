<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MenuController"
            prefWidth="800" prefHeight="600"
            style="-fx-background-color: linear-gradient(to bottom, #4CAF50, #2E7D32);">

    <!-- Judul Game -->
    <Label text="Petualangan Hijau"
           layoutX="200" layoutY="120"
           style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: white;" />

    <!-- Tombol Mulai -->
    <Button fx:id="btnStart"
            text="Mulai Petualangan"
            onAction="#startGame"
            layoutX="290" layoutY="300"
            prefWidth="220" prefHeight="55"
            style="-fx-font-size: 20px; -fx-background-color: #81C784; -fx-text-fill: white;"/>

    <!-- Tombol Keluar -->
    <Button text="Keluar"
            onAction="#exitGame"
            layoutX="290" layoutY="380"
            prefWidth="220" prefHeight="55"
            style="-fx-font-size: 20px; -fx-background-color: #66BB6A; -fx-text-fill: white;"/>
</AnchorPane>
