<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            fx:controller="controller.PrologController"
            prefWidth="1280"
            prefHeight="720"
            style="-fx-background-color: #000000;">

    <VBox spacing="40"
          alignment="CENTER"
          AnchorPane.leftAnchor="80.0"
          AnchorPane.rightAnchor="80.0"
          AnchorPane.topAnchor="60.0"
          AnchorPane.bottomAnchor="60.0">

        <Label fx:id="prologLabel"
               wrapText="true"
               text=""
               style="-fx-text-fill: #ffffff; -fx-font-size: 22px; -fx-font-family: 'Consolas';"/>

        <Label fx:id="hintLabel"
               text=""
               style="-fx-text-fill: #9acd32; -fx-font-size: 16px; -fx-font-weight: bold;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </Label>
    </VBox>
</AnchorPane>

